                    el: ".swiper-pagination",
                    clickable: true,
                },
                breakpoints: {
                    0: {
                        slidesPerView: 1,
                        spaceBetween: 20
                    }, // Mobile
                    640: {
                        slidesPerView: 3,
                        spaceBetween: 20
                    }, // Tablet
                    1024: {
                        slidesPerView: 5,
                        spaceBetween: 30
